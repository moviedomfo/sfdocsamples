@{
    ViewBag.Title = "Reporte de personas";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<script type="text/javascript">
    $(function () {

        $('#btnCall').on('click', function () {
            
            call_getall();
        });
    });

    function call_getall() {
        var varData = {

        }
        $.ajax({
            type: 'POST',
           
            url: httpHost + '/home/GetAll',
            dataType: 'json',
            contentType: "application/json;charset=utf-8",
            data: JSON.stringify(varData),
            success: function (result) {
                //if (ajaxContext.Result && ajaxContext.Result != 'OK') {

                $('#json_resul').text(JSON.stringify(result));
                //}
                angular.element($('#MyCtrl')).scope().myData = JSON.stringify(result);
               
                Mangular.element($('#MyCtrl')).scope().$apply();

            },
            error: function ServiceFailed(xhr, status, p3, p4) {
                var errMsg = status + " " + p3;
                errMsg = errMsg + "\n" + xhr.responseText;
                alert(errMsg);
                Showloading(false);
            }
        });
    }
</script>
@section styles {
    
<link href="~/Content/ng-grid.css" rel="stylesheet" />

    <style >

        .gridStyle {
            border: 1px solid rgb(212,212,212);
            width: 400px;
            height: 300px;
        }
    </style>
    
}


<button id="btnCall" type="button" class="btn btn-primary">llamar al svc</button>
<div id="json_resul"></div>
<div ng-app="myApp">
    
    <div ng-controller="MyCtrl as vm">
        <h1>Personas</h1>
        @*<p>
            <input class="form-control" placeholder="Search by Name" type="text" ng-model="vm.search" ng-model-options="{ debounce: 500 }" />
        </p>*@

        <div class="gridStyle" ng-grid="gridOptions">
        </div>
        <input type="button" value="Buscar enbase de datos" ng-click="vm.search()" />

    </div>
</div>


@section Scripts {

<script src="@Url.Content("~/Scripts/ng-grid.js")" type="text/javascript"></script>
   <script src="@Url.Content("~/Scripts/vm_angular/nggrid.js")" type="text/javascript"></script>
}
